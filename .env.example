# Copy to .env and fill in. .env is gitignored. See CLAUDE.md "Running the pipeline".
# Twelve Data API key — OHLC + market series (fetch.py).
TWELVE_DATA_KEY=
# FRED API key — macro series (DFII10, DGS2, VIX, ...).
FRED_KEY=
